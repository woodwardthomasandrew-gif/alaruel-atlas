{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@alaruel/core/*":    ["core/*/src"],
      "@alaruel/shared":    ["shared/src"],
      "@alaruel/ui":        ["ui/src"],
      "@alaruel/module-*":  ["modules/*/src"]
    }
  },
  "include": ["core", "modules", "ui", "shared", "apps"],
  "exclude": ["node_modules", "dist", "data"]
}
