{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": [
      "ES2022"
    ],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": ".vite/build",
    "rootDir": "../..",
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "../../core/**/*",
    "../../modules/**/*",
    "../../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "../../ui"
  ]
}