{
  "name": "@alaruel/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Alaruel Atlas — desktop wrapper",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "node dev.cjs",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "dev": "node dev.cjs",
    "predev": "npm install --prefix ../../ui",
    "build:main": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --external:better-sqlite3 --outfile=.vite/build/main.js --sourcemap",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --outfile=.vite/build/preload.js --sourcemap"
  },
  "dependencies": {
    "alaruel-atlas": "file:../..",
    "better-sqlite3": "^9.0.0",
    "electron": "^30.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-deb": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/maker-rpm": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/plugin-vite": "^7.0.0",
    "@electron-forge/shared-types": "^7.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "config": {
    "forge": "./forge.config.cjs"
  }
}
