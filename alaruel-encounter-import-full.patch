+.importBtnLinked{padding:.28rem .65rem;background:rgba(76,175,133,.1);border:1px solid #4caf85;border-radius:var(--radius-sm);color:#4caf85;font-size:.78rem;cursor:pointer;transition:all .12s;white-space:nowrap}
+.importBtnLinked:hover{background:rgba(76,175,133,.18)}
+.linkedSection{display:flex;flex-direction:column;gap:.4rem}
+.linkedLabel{font-size:.68rem;text-transform:uppercase;letter-spacing:.08em;color:var(--ink-500)}
+.linkedChips{display:flex;flex-wrap:wrap;gap:.3rem}
+.linkedChip{display:flex;align-items:center;gap:.3rem;padding:.18rem .5rem .18rem .6rem;background:rgba(196,144,64,.1);border:1px solid var(--gold-700);border-radius:20px;font-size:.78rem;color:var(--gold-400)}
+.chipRemove{background:none;border:none;cursor:pointer;color:var(--gold-600);font-size:.85rem;line-height:1;padding:0;display:flex;align-items:center}
+.chipRemove:hover{color:var(--crimson-400)}
+.monsterTable{display:flex;flex-direction:column;gap:.3rem}
+.monsterTableRow{display:flex;align-items:center;justify-content:space-between;gap:.6rem;padding:.4rem .6rem;background:var(--bg-surface);border:1px solid var(--gold-700);border-radius:var(--radius-sm)}
+.monsterTableInfo{display:flex;flex-direction:column;gap:.08rem;flex:1;min-width:0}
+.monsterTableName{font-size:.87rem;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
+.monsterTableMeta{font-size:.71rem;color:var(--ink-500)}
+.monsterTableNotes{font-size:.71rem;color:var(--gold-600);font-style:italic}
+.monsterTableControls{display:flex;align-items:center;gap:.3rem;flex-shrink:0}
+.countBtn{width:22px;height:22px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg-raised);color:var(--text-secondary);font-size:.85rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0}
+.countBtn:hover:not(:disabled){border-color:var(--gold-600);color:var(--gold-400)}
+.countBtn:disabled{opacity:.35;cursor:not-allowed}
+.countVal{font-family:var(--font-mono);font-size:.82rem;color:var(--text-primary);min-width:18px;text-align:center}
+.countInline{display:flex;align-items:center;gap:.2rem}
+.notesInline{background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-primary);font-family:var(--font-body);font-size:.78rem;padding:.25rem .45rem;outline:none;transition:border-color .15s;width:120px}
+.notesInline:focus{border-color:var(--gold-600)}
