+/* MonsterDetail — statblock view + inline editor */
+
+.panel {
+  display:flex; flex-direction:column;
+  overflow:hidden; height:100%;
+}
+
+/* ── Empty state ─────────────────────────────────────────────────────────── */
+.empty {
+  flex:1; display:flex; flex-direction:column; align-items:center;
+  justify-content:center; gap:.75rem; color:var(--text-muted);
+  font-family:var(--font-body); font-size:.95rem;
+}
+.emptyIcon { color:var(--ink-700); }
+
+/* ── Header bar ──────────────────────────────────────────────────────────── */
+.header {
+  display:flex; align-items:center; justify-content:space-between;
+  padding:.75rem 1.5rem; border-bottom:1px solid var(--border-subtle);
+  flex-shrink:0; gap:.75rem;
+}
+.headerTitle {
+  font-family:var(--font-display); font-size:1.15rem;
+  color:var(--text-accent); flex:1; min-width:0;
+  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
+}
+.headerMeta { font-size:.8rem; color:var(--text-muted); }
+
+.headerActions { display:flex; gap:.5rem; }
+
+.btnEdit, .btnSave, .btnCancel, .btnDelete {
+  display:flex; align-items:center; gap:.35rem;
+  padding:.38rem .75rem; border-radius:var(--radius-sm);
+  font-family:var(--font-body); font-size:.82rem;
+  cursor:pointer; transition:all .12s;
+}
+.btnEdit {
+  background:var(--bg-raised); border:1px solid var(--border);
+  color:var(--text-secondary);
+}
+.btnEdit:hover { border-color:var(--gold-600); color:var(--text-accent); }
+.btnSave {
+  background:var(--gold-600); border:1px solid var(--gold-500);
+  color:var(--ink-950); font-weight:600;
+}
+.btnSave:hover { background:var(--gold-500); }
+.btnSave:disabled { opacity:.5; cursor:not-allowed; }
+.btnCancel {
+  background:transparent; border:1px solid var(--border);
+  color:var(--text-muted);
+}
+.btnCancel:hover { border-color:var(--border); color:var(--text-secondary); }
+.btnDelete {
+  background:transparent; border:1px solid transparent;
+  color:var(--crimson-400);
+}
+.btnDelete:hover { background:rgba(196,64,64,.12); border-color:var(--crimson-600); }
+.btnDelete:disabled { opacity:.5; cursor:not-allowed; }
+
+/* ── Scroll body ─────────────────────────────────────────────────────────── */
+.body { flex:1; overflow-y:auto; padding:1.5rem; }
+
+/* ── Error banner ────────────────────────────────────────────────────────── */
+.errorBar {
+  display:flex; align-items:center; gap:.5rem; margin-bottom:1rem;
+  padding:.5rem .75rem; background:rgba(196,64,64,.1);
+  border:1px solid var(--crimson-600); border-radius:var(--radius-sm);
+  color:var(--crimson-400); font-size:.82rem;
+}
+
+/* ═══════════════════════════════════════════════════════════════════════════
+   STATBLOCK VIEW
+   ═══════════════════════════════════════════════════════════════════════════ */
+
+.statblock {
+  background:var(--bg-surface); border:1px solid var(--border);
+  border-radius:var(--radius-md); overflow:hidden;
+  max-width:720px; margin:0 auto;
+}
+
+/* Blood-red top bar */
+.statblockBanner {
+  background:var(--crimson-600); padding:.6rem 1.2rem;
+  display:flex; align-items:baseline; gap:.75rem; flex-wrap:wrap;
+}
+.sbName {
+  font-family:var(--font-display); font-size:1.35rem;
+  color:var(--ink-50); font-weight:700;
+}
+.sbTypeLine {
+  font-style:italic; font-size:.88rem; color:rgba(255,255,255,.75);
+}
+
+/* Gold divider ornament */
+.sbDivider {
+  height:6px;
+  background: linear-gradient(90deg, var(--gold-600), var(--gold-400), var(--gold-600));
+  opacity:.7;
+}
+
+.sbSection { padding:.75rem 1.2rem; border-bottom:1px solid var(--border-subtle); }
+.sbSection:last-child { border-bottom:none; }
+
+/* Core stats row (AC / HP / Speed) */
+.sbCoreStats { display:flex; flex-wrap:wrap; gap:1rem; }
+.sbCoreStat { display:flex; flex-direction:column; gap:.1rem; }
+.sbCoreLabel { font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; }
+.sbCoreValue { font-size:.95rem; color:var(--text-primary); font-weight:600; }
+
+/* Ability score grid */
+.abilityGrid {
+  display:grid; grid-template-columns:repeat(6,1fr);
+  gap:.5rem; text-align:center;
+}
+.abilityCell { display:flex; flex-direction:column; gap:.15rem; }
+.abilityLabel {
+  font-size:.65rem; text-transform:uppercase; letter-spacing:.07em;
+  color:var(--text-muted); font-family:var(--font-mono);
+}
+.abilityScore { font-size:1.05rem; color:var(--text-primary); font-weight:600; }
+.abilityMod { font-size:.78rem; color:var(--text-accent); }
+
+/* Properties list (saves, skills, resistances…) */
+.sbPropList { display:flex; flex-direction:column; gap:.35rem; }
+.sbProp { font-size:.88rem; line-height:1.4; }
+.sbPropKey { color:var(--text-accent); font-weight:600; margin-right:.35rem; }
+.sbPropVal { color:var(--text-primary); }
+
+/* CR badge */
+.crRow {
+  display:flex; align-items:center; gap:1.5rem;
+  font-size:.88rem; color:var(--text-primary);
+}
+.crBadge {
+  display:inline-flex; align-items:center;
+  background:var(--crimson-600); color:var(--ink-50);
+  font-family:var(--font-display); font-size:1.1rem;
+  padding:.2rem .8rem; border-radius:var(--radius-sm);
+}
+
+/* Actions / traits blocks */
+.blockList { display:flex; flex-direction:column; gap:.75rem; }
+.blockItem {}
+.blockName {
+  font-family:var(--font-display); font-size:.9rem;
+  color:var(--text-accent); margin-bottom:.2rem;
+}
+.blockDesc { font-size:.88rem; color:var(--text-secondary); line-height:1.55; }
+.blockAttack { font-size:.8rem; color:var(--text-muted); margin-top:.2rem; }
+
+/* Section heading */
+.sbHeading {
+  font-family:var(--font-display); font-size:.78rem;
+  text-transform:uppercase; letter-spacing:.12em;
+  color:var(--crimson-400); border-bottom:1px solid var(--crimson-600);
+  padding-bottom:.25rem; margin-bottom:.65rem;
+}
+
+/* Lore / GM notes area */
+.loreBlock {
+  background:var(--bg-raised); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); padding:.75rem 1rem;
+  font-size:.875rem; color:var(--text-secondary);
+  line-height:1.6; white-space:pre-wrap; margin-top:.5rem;
+}
+
+/* Tags */
+.tagList { display:flex; flex-wrap:wrap; gap:.35rem; margin-top:.4rem; }
+.tag {
+  font-size:.72rem; background:var(--bg-hover);
+  border:1px solid var(--border); color:var(--text-muted);
+  padding:.15rem .5rem; border-radius:20px;
+}
+
+/* ═══════════════════════════════════════════════════════════════════════════
+   EDIT FORM
+   ═══════════════════════════════════════════════════════════════════════════ */
+
+.editForm {
+  display:flex; flex-direction:column; gap:1.5rem;
+  max-width:760px; margin:0 auto;
+}
+
+.formSection {
+  background:var(--bg-surface); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-md); padding:1.1rem 1.3rem;
+}
+.formSectionTitle {
+  font-family:var(--font-display); font-size:.78rem;
+  text-transform:uppercase; letter-spacing:.1em;
+  color:var(--crimson-400); margin-bottom:.9rem;
+  padding-bottom:.35rem; border-bottom:1px solid var(--border-subtle);
+}
+
+.formRow { display:flex; gap:.85rem; flex-wrap:wrap; }
+.formGroup { display:flex; flex-direction:column; gap:.3rem; flex:1; min-width:120px; }
+.formGroupFull { display:flex; flex-direction:column; gap:.3rem; flex:1 1 100%; }
+
+.label { font-size:.75rem; color:var(--text-muted); font-family:var(--font-body); }
+
+.input, .select, .textarea {
+  background:var(--bg-raised); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); color:var(--text-primary);
+  font-family:var(--font-body); font-size:.88rem;
+  padding:.38rem .6rem; outline:none; width:100%;
+  transition:border-color .15s; box-sizing:border-box;
+}
+.input:focus, .select:focus, .textarea:focus { border-color:var(--gold-600); }
+.input::placeholder, .textarea::placeholder { color:var(--ink-500); }
+.textarea { resize:vertical; min-height:80px; line-height:1.5; }
+
+/* Ability score group — compact number inputs */
+.abilityInputGrid {
+  display:grid; grid-template-columns:repeat(6,1fr); gap:.5rem;
+}
+.abilityInputCell { display:flex; flex-direction:column; gap:.2rem; text-align:center; }
+.abilityInputLabel {
+  font-size:.65rem; text-transform:uppercase; letter-spacing:.07em;
+  color:var(--text-muted); font-family:var(--font-mono);
+}
+.abilityInput {
+  background:var(--bg-raised); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); color:var(--text-primary);
+  font-size:.9rem; padding:.3rem .2rem; outline:none;
+  text-align:center; width:100%; transition:border-color .15s;
+}
+.abilityInput:focus { border-color:var(--gold-600); }
+.abilityMod {
+  font-size:.7rem; color:var(--text-accent); text-align:center;
+}
+
+/* Dynamic action list */
+.actionList { display:flex; flex-direction:column; gap:.65rem; }
+.actionItem {
+  background:var(--bg-raised); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); padding:.75rem;
+}
+.actionItemHeader {
+  display:flex; align-items:center; gap:.5rem; margin-bottom:.5rem;
+}
+.actionItemTitle {
+  flex:1; background:var(--bg-base); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); color:var(--text-primary);
+  font-family:var(--font-display); font-size:.85rem;
+  padding:.3rem .5rem; outline:none; transition:border-color .15s;
+}
+.actionItemTitle:focus { border-color:var(--gold-600); }
+.removeBtn {
+  background:transparent; border:none; color:var(--ink-500);
+  cursor:pointer; padding:.2rem; transition:color .12s; flex-shrink:0;
+}
+.removeBtn:hover { color:var(--crimson-400); }
+.actionItemDesc {
+  width:100%; background:var(--bg-base); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); color:var(--text-primary);
+  font-family:var(--font-body); font-size:.83rem;
+  padding:.3rem .5rem; outline:none; resize:vertical; min-height:56px;
+  transition:border-color .15s; box-sizing:border-box;
+}
+.actionItemDesc:focus { border-color:var(--gold-600); }
+.actionSubRow { display:flex; gap:.5rem; margin-top:.4rem; }
+.actionSubInput {
+  flex:1; background:var(--bg-base); border:1px solid var(--border-subtle);
+  border-radius:var(--radius-sm); color:var(--text-secondary);
+  font-family:var(--font-mono); font-size:.78rem;
+  padding:.28rem .5rem; outline:none; transition:border-color .15s;
+}
+.actionSubInput:focus { border-color:var(--gold-600); }
+.actionSubInput::placeholder { color:var(--ink-600); }
+
+.addBtn {
+  display:flex; align-items:center; gap:.35rem;
+  padding:.35rem .7rem; background:transparent;
+  border:1px dashed var(--border); border-radius:var(--radius-sm);
+  color:var(--text-muted); font-size:.8rem; cursor:pointer;
+  transition:all .12s; width:100%; justify-content:center; margin-top:.25rem;
+}
+.addBtn:hover { border-color:var(--gold-600); color:var(--text-accent); }
+
+/* Tags editor */
